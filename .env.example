# Copy to .env for local dev. Do not commit .env.
# Get these from Lovable (project uses Lovable Cloud backend) or your own Supabase.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Z.AI and OpenAI are set in Lovable Cloud (Edge Function secrets), not here.
