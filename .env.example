# Supabase (required for frontend + Edge Function invocation)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# API keys are set in Supabase Edge Function secrets (not here):
# - ZAI_API_KEY (Z.AI API key for GLM)
# - LOVABLE_API_KEY (optional fallback when Z.AI is rate-limited)
