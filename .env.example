# Copy to .env and fill in with **your own** Supabase project values.
# Get these from your Supabase dashboard (Settings → API). Do not use or share others' keys.

# Supabase (required for frontend + Edge Function invocation)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# API keys are set in Supabase Edge Function secrets (not in .env):
# ZAI_API_KEY, LOVABLE_API_KEY — add in Supabase → Edge Functions → Secrets
